// Prisma schema for CommerceOS admin.
//
// Generates two surfaces:
//   1. Auth.js (v5) tables: User, Account, Session, VerificationToken.
//   2. Commerce domain: Category, Product, Inventory, Customer, Order, OrderItem.
//
// Money is stored as integer minor units (e.g. kuruş for TRY, cents for USD).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js ────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           Role      @default(VIEWER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  orders   Order[]   @relation("OrderCreatedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Commerce ───────────────────────────────────────────────────────────────

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  sku         String        @unique
  description String?
  price       Int // minor units (kuruş)
  costPrice   Int? // minor units, brüt kâr marjı için
  currency    String        @default("TRY")
  status      ProductStatus @default(DRAFT)
  images      Json          @default("[]")
  categoryId  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category   Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventory  Inventory?
  orderItems OrderItem[]
  reviews    ProductReview[]

  @@index([status])
  @@index([categoryId])
}

model ProductReview {
  id          String    @id @default(cuid())
  productId   String
  authorName  String
  authorEmail String?
  rating      Int // 1-5
  body        String
  reply       String?
  repliedAt   DateTime?
  isPublished Boolean   @default(true)
  // AI flag (otopilot autoAnalyzeReviews kuralı)
  aiFlagged     Boolean  @default(false)
  aiFlagReason  String? // 'şikayet' | 'kargo sorunu' | 'ürün sorunu' | 'iade talebi' | vb.
  aiFlagSentiment String? // 'positive' | 'neutral' | 'negative'
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([rating])
  @@index([aiFlagged, isPublished])
}

model Inventory {
  id           String   @id @default(cuid())
  productId    String   @unique
  quantity     Int      @default(0)
  reserved     Int      @default(0)
  reorderLevel Int      @default(5)
  location     String   @default("default")
  updatedAt    DateTime @updatedAt

  product     Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  adjustments InventoryAdjustment[]
}

enum AdjustmentReason {
  RESTOCK
  SALE
  RETURN
  LOSS
  CORRECTION
}

model InventoryAdjustment {
  id          String           @id @default(cuid())
  inventoryId String
  delta       Int // positive = stock added, negative = removed
  reason      AdjustmentReason @default(CORRECTION)
  note        String?
  userId      String?
  createdAt   DateTime         @default(now())

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId, createdAt])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  address   Json?
  notes     String?
  // AI segmentasyon (otopilot autoSegmentCustomers)
  aiSegment            String? // 'sadık' | 'yeni' | 'risky' | 'VIP' | vb.
  aiSegmentConfidence  Int? // 0-100
  aiSegmentUpdatedAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders          Order[]
  emails          CustomerEmail[]
  addresses       CustomerAddress[]
  deletionRequests DataDeletionRequest[]

  @@index([aiSegment])
}

model CustomerAddress {
  id          String   @id @default(cuid())
  customerId  String
  label       String? // 'Ev', 'İş', vb.
  fullName    String
  phone       String?
  line1       String
  line2       String?
  city        String
  district    String?
  postalCode  String?
  country     String   @default("TR")
  // Fatura adresi mi (kurumsal alanlar)?
  isCompany   Boolean  @default(false)
  taxId       String? // VKN / TCKN (fatura için)
  taxOffice   String? // vergi dairesi
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, isDefault])
}

model CustomerEmail {
  id          String   @id @default(cuid())
  customerId  String
  subject     String
  body        String   @db.Text
  status      String   @default("SENT") // 'QUEUED' | 'SENT' | 'FAILED' (mock)
  campaignTag String? // 'segment-loyalty', 'birthday', 'abandoned-cart', vb.
  errorMessage String?
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([campaignTag, createdAt])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  customerId  String
  createdById String?
  status      OrderStatus @default(PENDING)
  subtotal    Int
  tax         Int         @default(0)
  shipping    Int         @default(0)
  total       Int
  currency    String      @default("TRY")
  notes       String?
  // Adres snapshot (sipariş anında dondurulur — müşteri sonra adres değişirse etkilenmez)
  shippingAddress Json? // { fullName, phone, line1, line2, city, district, postalCode, country }
  billingAddress  Json? // aynı şekil + isCompany, taxId, taxOffice
  billingSameAsShipping Boolean @default(false)
  // Kargo entegrasyonu (mock — Aras/Yurtiçi/MNG)
  carrier        String? // 'ARAS' | 'YURTICI' | 'MNG' | 'PTT' | 'OTHER'
  trackingNumber String? @unique // kargo takip no
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  customer     Customer          @relation(fields: [customerId], references: [id])
  createdBy    User?             @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items        OrderItem[]
  refunds      Refund[]
  invoice      Invoice?
  bankPayments BankTransaction[]
  payments     Payment[]

  @@index([status])
  @@index([customerId])
}

enum PaymentStatus {
  PENDING       // checkout başlatıldı, ödeme bekleniyor
  AUTHORIZED    // ödeme yetkilendirildi (3DS sonrası)
  CAPTURED      // ödeme alındı (başarılı tahsilat)
  FAILED        // başarısız
  CANCELLED     // kullanıcı iptal etti
  REFUNDED      // iade edildi
}

model Payment {
  id                    String        @id @default(cuid())
  orderId               String
  gateway               String // 'iyzico' | 'manual'
  status                PaymentStatus @default(PENDING)
  amountMinor           Int
  currency              String        @default("TRY")
  // Gateway tarafı tanımlayıcılar
  gatewayPaymentId      String? // iyzico paymentId
  gatewayConversationId String? // bizim verdiğimiz unique reference
  gatewayToken          String? // checkout form token
  paymentLink           String? // checkoutFormUrl — müşteriye paylaşılır
  // 3DS / sonuç
  paidAt                DateTime?
  errorMessage          String?
  rawInit               Json? // initialize response
  rawCallback           Json? // callback payload
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([status])
  @@index([gatewayPaymentId])
}

enum RefundReason {
  CUSTOMER_REQUEST
  DEFECTIVE
  WRONG_ITEM
  LATE_DELIVERY
  CANCELLED
  OTHER
}

enum RefundStatus {
  PENDING
  COMPLETED
  REJECTED
}

model Refund {
  id        String       @id @default(cuid())
  orderId   String
  amount    Int // minor units
  reason    RefundReason @default(CUSTOMER_REQUEST)
  status    RefundStatus @default(PENDING)
  notes     String?
  userId    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

enum ExpenseCategory {
  RENT // Kira
  PAYROLL // Personel/maaş
  SHIPPING // Kargo
  MARKETING // Pazarlama
  SUPPLIES // Ofis/malzeme
  COGS // Satılan mal maliyeti
  TAXES // Vergi/SGK
  UTILITIES // Fatura (elektrik/su/internet)
  SOFTWARE // Yazılım/SaaS
  TRAVEL // Seyahat
  OTHER // Diğer
}

enum RecurrenceRule {
  MONTHLY // her ay dueDay'de
  WEEKLY // her hafta dueDay (0=pazar...6=cumartesi)
  QUARTERLY // 3 ayda bir
  YEARLY // yılda bir
  ONE_TIME // tek seferlik (startDate'de)
}

// Gelecek/tekrarlayan ödemeler — kira, maaş, abonelik vb.
// AI cash flow forecast bu listeyi kesin ödeme olarak kabul eder.
model ScheduledPayment {
  id          String          @id @default(cuid())
  name        String // 'Personel maaşı', 'Ofis kirası'
  amount      Int // kuruş
  currency    String          @default("TRY")
  category    ExpenseCategory @default(OTHER)
  recurrence  RecurrenceRule  @default(MONTHLY)
  // MONTHLY/QUARTERLY/YEARLY: 1-31 (gün), WEEKLY: 0-6 (haftanın günü).
  dueDay      Int
  startDate   DateTime // ilk vade
  endDate     DateTime? // null → süresiz
  active      Boolean         @default(true)
  notes       String?
  vendor      String? // alıcı / firma
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([active, startDate])
  @@index([category])
}

model SalesGoal {
  // period 'YYYY-MM' — aylık hedef. Tek satır per ay (unique).
  id           String   @id @default(cuid())
  period       String   @unique
  targetAmount Int // minor units (kuruş), TRY varsayar
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Expense {
  id          String          @id @default(cuid())
  date        DateTime
  amount      Int // minor units (kuruş)
  currency    String          @default("TRY")
  category    ExpenseCategory @default(OTHER)
  description String
  vendor      String?
  reference   String? // fatura numarası vb.
  userId      String?
  // Tekrarlayan gider (kira, personel, abonelik)
  recurringRule     String? // 'MONTHLY' | 'WEEKLY' | 'QUARTERLY' | 'YEARLY' | null
  recurringParentId String? // ata expense (orijinal şablon) — turevler ona pointer
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  recurringParent  Expense?  @relation("ExpenseRecurring", fields: [recurringParentId], references: [id], onDelete: SetNull)
  recurringChildren Expense[] @relation("ExpenseRecurring")

  @@index([date])
  @@index([category, date])
  @@index([recurringRule, recurringParentId])
}

model SystemSettings {
  // Singleton row — there is only ever one record, keyed by literal "default".
  id              String   @id @default("default")
  companyName     String   @default("CommerceOS Demo")
  taxId           String?
  address         String?
  phone           String?
  email           String?
  defaultCurrency String   @default("TRY")
  defaultTaxRate  Float    @default(0)
  timezone        String   @default("Europe/Istanbul")
  // GİB e-fatura entegrasyonu — test ortamında mock, prod'da kullanıcının
  // entegratörüne (Foriba/Logo/BIM) yönlendirilir.
  gibMode              String   @default("test") // "test" | "production"
  gibIntegratorUrl     String? // Prod modda zorunlu (entegratör SOAP/REST URL'i)
  gibUsername          String?
  gibPasswordEncrypted String? // demo: plaintext OK; prod'da encrypt
  gibSenderAlias       String? // GİB'de firma alias'ı (urn:mail:test@firma.com.tr)
  // Banka entegrasyonu (havale/EFT eşleştirme)
  // Test mode'da local mock simülatör; prod'da gerçek banka webhook URL ile
  // BDDK lisanslı bağlantı (hackathon scope dışı, architecture-ready)
  bankMode             String   @default("test") // "test" | "production"
  bankWebhookSecret    String? // HMAC doğrulaması için
  bankAccountIban      String? // Mağazanın IBAN'ı, fatura/sipariş eşleştirmesinde
  bankName             String? // 'Test Bankası' / gerçek banka adı
  // iyzico ödeme entegrasyonu
  iyzicoMode           String   @default("test") // 'test' | 'production'
  iyzicoApiKey         String? // production'da gizli, test'te sandbox key kullanılır
  iyzicoSecretKey      String? // production'da gizli
  iyzicoCallbackUrl    String? // tunnel URL gerek (Cloudflare/ngrok)
  // Otopilot Modu — AI'a tüm operasyonu devret
  autoPilotEnabled            Boolean @default(false)
  autoPilotMonthlyBudgetMinor Int? // Aylık operasyon bütçesi (kuruş)
  autoPilotConfidenceThreshold Int @default(75) // 0-100, AI minimum güven eşiği
  // ─── Yorumlar grubu ───
  autoPilotAutoReplyReviews     Boolean @default(true) // yeni yoruma cevap
  autoPilotAutoAnalyzeReviews   Boolean @default(true) // negatif yorumu flag
  // ─── Finans grubu ───
  autoPilotAutoIssueInvoices    Boolean @default(true) // CONFIRMED'da fatura kes
  autoPilotAutoMatchBank        Boolean @default(true) // havale eşik düşür
  autoPilotAutoConfirmOrders    Boolean @default(false) // havale eşleşince CONFIRMED'a al (riskli)
  // ─── Stok & Tedarikçi ───
  autoPilotAutoReorderStock     Boolean @default(true) // stok düşünce sipariş
  autoPilotAutoSuggestPrice     Boolean @default(false) // haftalık fiyat önerisi
  // ─── Müşteri ───
  autoPilotAutoSegmentCustomers Boolean @default(true) // yeni müşteri AI segment
  autoPilotEnabledAt          DateTime?
  // Onboarding wizard
  onboardingCompletedAt       DateTime?
  // KVKK
  privacyPolicyText           String?  @db.Text
  privacyPolicyUpdatedAt      DateTime?
  cookieBannerEnabled         Boolean  @default(true)
  dataController              String?
  dpoEmail                    String?
  updatedAt            DateTime @updatedAt
}

enum DataDeletionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model DataDeletionRequest {
  id            String              @id @default(cuid())
  customerId    String?
  customerEmail String
  customerName  String?
  reason        String?             @db.Text
  status        DataDeletionStatus  @default(PENDING)
  reviewedBy    String? // admin user id
  reviewNote    String?             @db.Text
  reviewedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([customerEmail])
}

enum AutoPilotActionType {
  REVIEW_REPLY     // AI yorum cevabı yazdı
  INVOICE_ISSUE    // AI sipariş için e-fatura kesti
  STOCK_REORDER    // AI tedarikçiye sipariş maili attı
  BANK_MATCH       // AI havale eşleştirdi (otopilot threshold)
  ORDER_CONFIRM    // AI siparişi CONFIRMED'a aldı (ödeme matched sonrası)
}

enum AutoPilotActionStatus {
  PENDING    // AI önerdi, bekleyen onay
  EXECUTED   // AI otomatik gerçekleştirdi
  FAILED     // başarısız (sebep error'da)
  SKIPPED    // confidence düşük veya kural devre dışı
}

model AutoPilotAction {
  id          String                @id @default(cuid())
  type        AutoPilotActionType
  status      AutoPilotActionStatus @default(PENDING)
  triggerSource String // 'order:cmX', 'review:cmY', 'stock:cmZ', vb.
  triggerSummary String  @db.Text // İnsan-okunabilir tetikleyici özeti
  decision    String                @db.Text // AI'nın kararı (kısa)
  reasoning   String?               @db.Text // AI'nın gerekçesi (uzun)
  confidence  Int? // 0-100
  resultRef   String? // İşlem tamamlandığında oluşan kayıt ref'i
  errorMessage String?
  metadata    Json?
  executedAt  DateTime?
  createdAt   DateTime              @default(now())

  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([triggerSource])
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  contactPerson String?
  address     String?
  notes       String?
  // Bu tedarikçi hangi ürünleri sağlıyor (SKU listesi, basit array)
  productSkus String[] @default([])
  // Sipariş geçildikten sonra teslim süresi (gün)
  leadTimeDays Int?     @default(7)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([email])
  @@index([isActive])
}

enum BankTransactionStatus {
  UNMATCHED       // hiç eşleştirilmemiş
  AUTO_MATCHED    // AI otomatik eşleştirdi (≥85% confidence)
  MANUAL_MATCHED  // kullanıcı manuel eşleştirdi
  IGNORED         // alakasız tx (komisyon, transfer, vb.)
}

enum BankTransactionDirection {
  IN   // gelen havale (tahsilat)
  OUT  // giden havale (gider/iade)
}

model BankTransaction {
  id              String                   @id @default(cuid())
  bankName        String
  accountIban     String?
  reference       String? // banka tarafından verilen referans no (varsa)
  transactionDate DateTime
  amountMinor     Int // pozitif IN, negatif OUT (kuruş)
  currency        String                   @default("TRY")
  description     String                   @db.Text // havale açıklaması
  direction       BankTransactionDirection
  source          String // 'CSV' | 'WEBHOOK' | 'MANUAL'
  status          BankTransactionStatus    @default(UNMATCHED)

  // Eşleştirme
  matchedOrderId  String?
  matchConfidence Int? // 0-100 (AI confidence)
  matchReasoning  String?                  @db.Text
  matchedAt       DateTime?
  matchedBy       String? // 'AI' | 'USER:userId'

  rawData   Json? // ham CSV satırı veya webhook payload (debug/audit)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matchedOrder Order? @relation(fields: [matchedOrderId], references: [id], onDelete: SetNull)

  @@unique([bankName, reference])
  @@index([status, transactionDate])
  @@index([matchedOrderId])
  @@index([direction, status])
}

enum InvoiceStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  CANCELLED
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique // GIB-2026000001 vb.
  orderId       String        @unique
  status        InvoiceStatus @default(DRAFT)
  documentType  String        @default("EFATURA") // 'EFATURA' (B2B/VKN) | 'EARSIV' (B2C/son tüketici)
  ublXml        String        @db.Text // UBL-TR 1.2 XML
  uuid          String        @unique // GİB UUID (test'te local generate)
  totalMinor    Int
  taxMinor      Int           @default(0)
  currency      String        @default("TRY")
  mode          String        @default("test") // 'test' | 'production'
  sentAt        DateTime?
  acceptedAt    DateTime?
  cancelledAt   DateTime?
  cancelReason  String?
  errorMessage  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([documentType])
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String // dot.path: 'product.create', 'order.transition', 'refund.create'
  entityType String?
  entityId   String?
  userId     String?
  userName   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([userId])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String // snapshot at time of order
  quantity  Int
  unitPrice Int // minor units, snapshot
  total     Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

enum DiscountType {
  PERCENTAGE // value 0-100
  FIXED // value in minor units (e.g. 5000 = 50.00 TRY off)
}

model Discount {
  id              String       @id @default(cuid())
  code            String       @unique
  description     String?
  type            DiscountType
  value           Int
  minSubtotal     Int          @default(0) // minor units gating the discount
  maxRedemptions  Int? // null = unlimited
  redemptionCount Int          @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([isActive, endsAt])
}
