# Copy to .env.local for local dev. .env* files are gitignored.

# Database (Prisma)
DATABASE_URL="postgresql://commerceos:commerceos@localhost:5432/commerceos?schema=public"

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# OAuth (optional, leave blank to disable Google sign-in)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Internal AI service (FastAPI on docker)
AI_SERVICE_URL=http://localhost:8000
