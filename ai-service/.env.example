# Copy to .env. .env files are gitignored.

GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash

REDIS_URL=redis://redis:6379

LOG_LEVEL=info

# Read-only Postgres for query_database tool. AI service needs SELECT-only
# rights — see db/init/01-readonly-user.sql for setup.
READONLY_DATABASE_URL=postgresql://commerceos_readonly:readonly_pwd_2026@postgres:5432/commerceos
QUERY_MAX_ROWS=200
QUERY_TIMEOUT_SECONDS=8
